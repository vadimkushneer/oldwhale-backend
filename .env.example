# Lightweight backend runtime
PORT=8080
SQLITE_PATH=./data/oldwhale.sqlite
JWT_SECRET=replace-with-a-long-random-secret-at-least-32-chars
JWT_TTL=24h
CORS_ORIGIN=http://localhost:5173,https://localhost,capacitor://localhost
FRONTEND_BASE_URL=http://localhost:5173

# Email registration and password reset. In development, missing SMTP_HOST logs
# OTPs/reset links to the backend console. In production, SMTP_HOST is required.
REGISTRATION_OTP_TTL_SECONDS=600
REGISTRATION_SETUP_TTL_SECONDS=900
PASSWORD_RESET_TTL_SECONDS=3600
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Old Whale <no-reply@oldwhale.local>

# Initial admin bootstrap. If all three are set, the user is created on startup.
INITIAL_ADMIN_USERNAME=adminantonvagiz
INITIAL_ADMIN_PASSWORD=replace-with-a-strong-password
INITIAL_ADMIN_EMAIL=admin@oldwhale.local

# AI provider keys. Admin AI groups reference these names, not their values.
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_API_KEY=

# VTB KZ payment gateway (redirect integration). When username and password are set,
# POST /api/me/credits/topup is disabled and top-ups go through POST /api/me/payments.
# Sandbox base URL: https://vtbkz.rbsuat.com/payment/rest/
VTB_API_BASE_URL=https://vtbkz.rbsuat.com/payment/rest/
# Merchant API credentials (VTB_API_USERNAME/PASSWORD are legacy aliases).
VTB_MERCHANT_USERNAME=
VTB_MERCHANT_PASSWORD=
# Optional explicit callback URL (defaults to API_PUBLIC_BASE_URL + /api/payments/vtb/callback).
VTB_DYNAMIC_CALLBACK_URL=
# Optional HMAC key for verifying VTB checksum callbacks.
VTB_CALLBACK_SECRET=
# Public backend origin for VTB callbacks when VTB_DYNAMIC_CALLBACK_URL is unset.
API_PUBLIC_BASE_URL=
