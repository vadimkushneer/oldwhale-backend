# Local dev. On App Platform / Render, omit HTTP_ADDR and use PORT (injected by host).
HTTP_ADDR=:8080
# Leave empty to use SQLite (DB_PATH). Set for PostgreSQL (DigitalOcean, Render, etc.):
# DATABASE_URL=postgres://USER:PASSWORD@HOST:25060/defaultdb?sslmode=require
DB_PATH=./data/oldwhale.db
JWT_SECRET=change-me-to-a-long-random-string
# GitHub Pages: use origin only (no path), e.g. https://youruser.github.io
CORS_ORIGIN=http://localhost:5173
ADMIN_LOGIN=admin
ADMIN_PASSWORD=admin123
ADMIN_EMAIL=admin@oldwhale.local
