# Lightweight backend runtime
PORT=8080
SQLITE_PATH=./data/oldwhale.sqlite
JWT_SECRET=replace-with-a-long-random-secret-at-least-32-chars
JWT_TTL=24h
CORS_ORIGIN=http://localhost:5173,https://localhost,capacitor://localhost
FRONTEND_BASE_URL=http://localhost:5173
PUBLIC_API_BASE_URL=http://localhost:8080

# Email registration and password reset. In development, missing SMTP_HOST logs
# OTPs/reset links to the backend console. In production, SMTP_HOST is required.
REGISTRATION_OTP_TTL_SECONDS=600
REGISTRATION_SETUP_TTL_SECONDS=900
PASSWORD_RESET_TTL_SECONDS=3600
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Old Whale <no-reply@oldwhale.local>

# VTB Bank Kazakhstan ecommerce payments. `amount` is sent in minor KZT units.
VTB_API_BASE_URL=https://vtbkz.rbsuat.com/payment/rest/
VTB_USER_NAME=Oldwhale-api
VTB_PASSWORD=Oldwhale
VTB_TOKEN=
VTB_CURRENCY=398
VTB_LANGUAGE=ru
# Optional. Must be HTTPS. Leave empty for local/HTTP deployments; VTB hosted
# payment sessions can fail if a plain HTTP dynamic callback URL is supplied.
VTB_DYNAMIC_CALLBACK_URL=
VTB_KZT_MINOR_UNITS_PER_OWK=100
VTB_SESSION_TIMEOUT_SECONDS=18000

# Initial admin bootstrap. If all three are set, the user is created on startup.
INITIAL_ADMIN_USERNAME=adminantonvagiz
INITIAL_ADMIN_PASSWORD=replace-with-a-strong-password
INITIAL_ADMIN_EMAIL=admin@oldwhale.local

# AI provider keys. Admin AI groups reference these names, not their values.
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_API_KEY=
