# Lightweight backend runtime
PORT=8080
SQLITE_PATH=./data/oldwhale.sqlite
JWT_SECRET=replace-with-a-long-random-secret-at-least-32-chars
JWT_TTL=24h
CORS_ORIGIN=http://localhost:5173,https://localhost,capacitor://localhost
FRONTEND_BASE_URL=http://localhost:5173

# Email registration and password reset. In development, missing SMTP_HOST logs
# OTPs/reset links to the backend console. In production, SMTP_HOST is required.
REGISTRATION_OTP_TTL_SECONDS=600
REGISTRATION_SETUP_TTL_SECONDS=900
PASSWORD_RESET_TTL_SECONDS=3600
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Old Whale <no-reply@oldwhale.local>

# Initial admin bootstrap. If all three are set, the user is created on startup.
INITIAL_ADMIN_USERNAME=adminantonvagiz
INITIAL_ADMIN_PASSWORD=replace-with-a-strong-password
INITIAL_ADMIN_EMAIL=admin@oldwhale.local

# AI provider keys. Admin AI groups reference these names, not their values.
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_API_KEY=

# ---------------------------------------------------------------------------
# VTB Kazakhstan eCommerce payment gateway (RBS platform). Credits = OWK.
# 1 OWK = 1 KZT; KZT has 100 tiyin, so the gateway amount is credits * 100.
# ---------------------------------------------------------------------------
# REST base (sandbox by default; production: https://payment.vtb.kz/payment/rest/)
VTB_API_BASE_URL=https://vtbkz.rbsuat.com/payment/rest/
# Merchant API account (the "-api" login) OR a token (leave user/pass empty if using a token).
# Legacy aliases are also accepted for back-compat: VTB_USER_NAME -> VTB_API_USERNAME,
# VTB_PASSWORD -> VTB_API_PASSWORD, VTB_TOKEN -> VTB_API_TOKEN.
VTB_API_USERNAME=
VTB_API_PASSWORD=
VTB_API_TOKEN=
# ISO 4217 numeric currency code (398 = KZT) and minor units per 1 OWK credit.
VTB_CURRENCY=398
VTB_MINOR_UNITS_PER_CREDIT=100
# Payment page language: ru | en | hy | az
VTB_LANGUAGE=ru
# Order lifetime (seconds) and HTTP timeout (ms) for gateway calls.
VTB_SESSION_TIMEOUT_SECS=1200
VTB_HTTP_TIMEOUT_MS=15000
# SPA path the payer returns to; the local payment id is appended as a path segment.
VTB_RETURN_PATH=/payment/return
# Optional shared symmetric key to verify checksum callbacks (HMAC-SHA256).
VTB_CALLBACK_CHECKSUM_KEY=
# Public, internet-reachable base URL of THIS backend, used to build the per-order
# dynamicCallbackUrl (e.g. https://api.oldwhale.example). Leave empty to omit it.
PUBLIC_API_BASE_URL=
# DEV ONLY: when true, POST /api/me/credits/topup mints free credits (no gateway).
# Leave empty/false in production.
DEV_FREE_TOPUP_ENABLED=
